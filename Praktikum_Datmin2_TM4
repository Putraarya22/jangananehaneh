t(f\"\\nCluster {i} top terms:\")\n","    print(\", \".join(top_terms))\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"qVJumoZazX63","executionInfo":{"status":"ok","timestamp":1757642391876,"user_tz":-420,"elapsed":115,"user":{"displayName":"Putra","userId":"11595020098672015861"}},"outputId":"918a5cc9-4094-4049-e0a4-f81b6b321e5d"},"execution_count":13,"outputs":[{"output_type":"stream","name":"stdout","text":["Shape TF-IDF: (10, 726)\n","Label cluster tiap dokumen: [1 2 2 0 2 2 0 2 0 2]\n","\n","Cluster 0 top terms:\n","negara, indonesia, untung, ekonomi, soeharto, perintah, jadi, tahun, daulat, satu\n","\n","Cluster 1 top terms:\n","buku, catat, hari, ahli, transaksi, tunggal, kas, keluar, akuntansi, sistem\n","\n","Cluster 2 top terms:\n","investasi, obligasi, deposito, investor, laba, usaha, saham, efek, modal, bursa\n"]}]},{"cell_type":"markdown","source":["Buat visualisasi clusternya dan lakukan interpretasi terhadap hasil tersebut"],"metadata":{"id":"LM_hasuj43Pr"}},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","from sklearn.decomposition import PCA\n","\n","# Reduksi dimensi ke 2 komponen utama\n","pca = PCA(n_components=2, random_state=42)\n","X_pca = pca.fit_transform(X.toarray())  # Ubah sparse matrix TF-IDF jadi array\n","\n","# Scatter plot hasil clustering\n","plt.figure(figsize=(8,6))\n","plt.scatter(X_pca[:,0], X_pca[:,1], c=C_km, cmap=\"viridis\", s=80, edgecolors=\"k\")\n","\n","# Tambahkan label dokumen biar jelas\n","for i, topic in enumerate(wiki_content_dict.keys()):\n","    plt.text(X_pca[i,0]+0.02, X_pca[i,1]+0.02, topic, fontsize=9)\n","\n","plt.title(\"Visualisasi Clustering Dokumen dengan PCA (TF-IDF + KMeans)\", fontsize=14)\n","plt.xlabel(\"PC 1\")\n","plt.ylabel(\"PC 2\")\n","plt.colorbar(label=\"Cluster\")\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":565},"id":"F8Qw81kFzu_d","executionInfo":{"status":"ok","timestamp":1757642431615,"user_tz":-420,"elapsed":718,"user":{"displayName":"Putra","userId":"11595020098672015861"}},"outputId":"9a9d2c18-5b34-4ddd-c80c-d3532683f281"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 2 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Clustering Per kata"],"metadata":{"id":"cke7DjRusi-O"}},{"cell_type":"code","source":["from sklearn.cluster import KMeans\n","from sklearn.decomposition import PCA\n","import matplotlib.pyplot as plt\n","import numpy as np\n","\n","# === 1. Ambil matriks TF-IDF per kata (transpose) ===\n","X_words = X.T  # shape: (jumlah_kata, jumlah_dokumen)\n","\n","# === 2. Clustering kata ===\n","k_words = 5  # jumlah cluster kata, bisa diubah\n","km_words = KMeans(n_clusters=k_words, random_state=42)\n","C_words = km_words.fit_predict(X_words.toarray())\n","\n","# === 3. Reduksi dimensi untuk visualisasi ===\n","pca = PCA(n_components=2, random_state=42)\n","X_words_pca = pca.fit_transform(X_words.toarray())\n","\n","# === 4. Ambil daftar kata ===\n","terms = np.array(tfidf_vectorizer.get_feature_names_out())\n","\n","# === 5. Scatter plot ===\n","plt.figure(figsize=(14,10))\n","plt.scatter(\n","    X_words_pca[:,0],\n","    X_words_pca[:,1],\n","    c=C_words,\n","    cmap=\"tab10\",\n","    s=60,\n","    alpha=0.7,\n","    edgecolors=\"k\"\n",")\n","\n","for i, word in enumerate(terms):\n","    plt.text(\n","        X_words_pca[i,0]+0.02,\n","        X_words_pca[i,1]+0.02,\n","        word,\n","        fontsize=8\n","    )\n","\n","plt.title(\"Visualisasi Clustering Kata (TF-IDF Transpose + KMeans)\", fontsize=16)\n","plt.xlabel(\"PC 1\")\n","plt.ylabel(\"PC 2\")\n","plt.colorbar(label=\"Cluster\")\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":874},"id":"7iKoGyhWqpT6","executionInfo":{"status":"ok","timestamp":1757642773671,"user_tz":-420,"elapsed":3953,"user":{"displayName":"Putra","userId":"11595020098672015861"}},"outputId":"fe